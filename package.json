{
  "name": "@howdoi-cli/cli",
  "version": "0.1.8",
  "description": "Intent-based Unix & Git command discovery. Meet your terminal where you stand.",
  "type": "module",
  "bin": {
    "howdoi": "./dist/cli.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "publish:npm": "npm publish --access public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "fuse.js": "^7.0.0",
    "js-yaml": "^4.1.0",
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "cli",
    "unix",
    "terminal",
    "linux",
    "git",
    "commands",
    "developer-tools",
    "cheatsheet",
    "tldr",
    "howdoi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SiphoChris/howdoi.git"
  },
  "homepage": "https://github.com/SiphoChris/howdoi#readme",
  "bugs": {
    "url": "https://github.com/SiphoChris/howdoi/issues"
  }
}